# Model weights
*.pt

# Node modules
node_modules/

# pipeline_cache.json and fraud_model.pkl are intentionally committed
# pipeline_cache.json slimmed to ~20MB (transactions capped at 150/alert)
# fraud_model.pkl is ~648KB
data/*.csv

# Demo/test CSVs generated for the Predict tab. MUST stay ignored: the HF
# deploy script does `git add -A` onto a temp branch then `git checkout -f
# main`, which deletes any tracked-only-on-that-branch file from the working
# tree. Ignoring them keeps deploys from eating these files.
/argus_*.csv

# Private prep notes — keep out of the public repo (candid weaknesses / answers)
/EVALUATOR_BRIEF.md

# Local pip wheel cache � never commit (huge, platform-specific)
wheels/
