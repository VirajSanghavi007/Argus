# Copy to .env (or set as real env vars / HF Space secrets) and fill in.
# Argus reads these via os.environ / os.getenv — see src/config.py and
# src/database/service.py for exactly where each one is consumed.

# ── Required ──────────────────────────────────────────────────────────────
# PostgreSQL connection string. Argus has no local-file fallback — the app
# will not start without this. Use the Supabase "Session pooler" URI (IPv4
# compatible) or any managed Postgres connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Recommended ───────────────────────────────────────────────────────────
# Salt used when hashing user passwords (see db._hash_password). Change this
# from the default in any real deployment — anyone with the default salt
# and a password guess can precompute matching hashes.
ARGUS_SECRET=change-me-to-a-long-random-string

# ── Optional ──────────────────────────────────────────────────────────────
# If set, POST /ingest requires this value in the X-API-Key header.
# Leave unset to allow unauthenticated ingestion (fine for a demo).
ARGUS_INGEST_KEY=

# Host/port the server binds to. Defaults shown — HF Spaces / most PaaS
# override PORT automatically, you rarely need to set these yourself.
HOST=0.0.0.0
PORT=8000

# Cap on how many transaction rows the pipeline reads from the dataset when
# building the graph. HI-Medium's first rows are low-connectivity; 800000
# reaches denser activity and produces a healthy alert set.
MULTIGNN_MAX_ROWS=800000
