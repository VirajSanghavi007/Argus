{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "src.backend.api.main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "autoPort": false,
      "env": {
        "PYTHONPATH": "."
      }
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite"],
      "port": 5173,
      "cwd": "src/frontend"
    }
  ]
}
